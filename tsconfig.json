{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["es2022"],
    "rootDir": "lib",
    "outDir": "dist",
    "declaration": true,
    "strict": true,
    "noImplicitReturns": true,
    "skipLibCheck": true,
    "sourceMap": true
  },
  "include": ["lib/**/*.ts"],
  "exclude": ["node_modules", "cdk.out", "dist", "test", "**/*.test.ts", "**/*.spec.ts"]
}
