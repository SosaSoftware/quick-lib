# ==========================================================
# Node.js Dependencies
# ==========================================================
# Installed packages (never commit)
node_modules/

# ==========================================================
# Build Artifacts (TypeScript / Library Output)
# ==========================================================
# Compiled output directory
dist/
build/
out/

# TypeScript incremental compilation metadata
*.tsbuildinfo

# Test coverage output
coverage/

# ==========================================================
# AWS CDK Artifacts
# ==========================================================
# Cloud assembly output (generated by synth)
cdk.out/

# Temporary CDK staging directory
.cdk.staging/

# CDK context cache (safe to ignore in libraries)
cdk.context.json

# ==========================================================
# Environment Configuration
# ==========================================================
# Local environment variables
.env
.env.*
!.env.example

# ==========================================================
# Logs
# ==========================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================================================
# JetBrains IDEs (WebStorm / IntelliJ)
# ==========================================================
# Project-specific IDE configuration
.idea/

# Legacy project files
*.iws
*.iml
*.ipr

# ==========================================================
# Operating System Files
# ==========================================================
.DS_Store
Thumbs.db
